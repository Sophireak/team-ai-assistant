{
  "name": "yourname/team-ai-assistant",
  "description": "AI-powered development assistant for Laravel teams — checks code quality, explains issues, and maintains consistency before every push.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "laravel",
    "ai",
    "code-quality",
    "git-hooks",
    "developer-tools"
  ],
  "authors": [
    {
      "name": "Sophireak",
      "email": "phereak00@gmail.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "illuminate/console": "^11.0",
    "illuminate/support": "^11.0",
    "illuminate/http": "^11.0"
  },
  "require-dev": {
    "orchestra/testbench": "^9.0",
    "phpunit/phpunit": "^11.0",
    "mockery/mockery": "^1.6"
  },
  "autoload": {
    "psr-4": {
      "YourName\\TeamAIAssistant\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "YourName\\TeamAIAssistant\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "YourName\\TeamAIAssistant\\TeamAIAssistantServiceProvider"
      ]
    }
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
